local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Garden Horizons | All Seeds Edition",
   LoadingTitle = "Načítám Billovu nabídku...",
   ConfigurationSaving = { Enabled = false }
})

-- ANTI-AFK
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

local settings = { Items = {} }

local function buy(name)
    _G.TargetItem = name
    pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/deafyisgoingnow-spec/Auto-farm-donation-clicker/refs/heads/main/Garden%20horizons"))()
    end)
end

spawn(function()
    while task.wait(0.5) do
        for name, enabled in pairs(settings.Items) do
            if enabled then buy(name) end
        end
    end
end)

-- SEED SHOP (Vše co jsme ve videích našli)
local SeedTab = Window:CreateTab("Seed Shop", 4483362458)
local allSeeds = {
    "Corn Seed", "Onion Seed", "Strawberry Seed", "Mushroom Seed", 
    "Beetroot Seed", "Tomato Seed", "Apple Seed", "Rose Seed", 
    "Wheat Seed", "Banana Seed", "Plum Seed", "Potato Seed", 
    "Cabbage Seed", "Cherry Seed", "Carrot Seed", "Goldenberry Seed"
}

for _, name in pairs(allSeeds) do
    settings.Items[name] = false
    SeedTab:CreateToggle({
       Name = "Auto Buy " .. name,
       CurrentValue = false,
       Callback = function(v) settings.Items[name] = v end,
    })
end

-- GEAR SHOP (Molly's Gear Shop)
local GearTab = Window:CreateTab("Gear Shop", 4483362458)
local allGears = {
    "Watering Can", "Basic Sprinkler", "Harvest Bell", 
    "Turbo Sprinkler", "Favorite Tool", "Super Sprinkler", "Shovel"
}

for _, name in pairs(allGears) do
