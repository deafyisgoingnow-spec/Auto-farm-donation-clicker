-- Načtení knihovny Rayfield
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Vytvoření okna
local Window = Rayfield:CreateWindow({
   Name = "Garden Horizons | Auto Buy & Anti-AFK",
   LoadingTitle = "Příprava systému...",
   ConfigurationSaving = { Enabled = false }
})

-- ANTI-AFK SYSTÉM (Běží hned po startu)
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
    print("Anti-AFK: Zabráněno odpojení!")
end)

-- Nastavení pro přepínače
local settings = {
    Seeds = {
        ["Mushroom Seed"] = false, ["Beetroot Seed"] = false, ["Tomato Seed"] = false,
        ["Apple Seed"] = false, ["Rose Seed"] = false, ["Wheat Seed"] = false,
        ["Banana Seed"] = false, ["Plum Seed"] = false, ["Potato Seed"] = false,
        ["Cabbage Seed"] = false, ["Cherry Seed"] = false
    },
    Gears = {
        ["Watering Can"] = false, ["Basic Sprinkler"] = false, ["Harvest Bell"] = false,
        ["Turbo Sprinkler"] = false, ["Favorite Tool"] = false, ["Super Sprinkler"] = false
    }
}

-- Funkce pro nákup využívající tvůj GitHub loadstring
local function doPurchase(itemName)
    -- Načte tvůj nákupní skript z GitHubu
    loadstring(game:HttpGet("https://raw.githubusercontent.com/deafyisgoingnow-spec/Auto-farm-donation-clicker/refs/heads/main/Garden%20horizons"))()
    -- Poznámka: Tvůj GitHub skript musí obsahovat logiku, která zpracuje 'itemName'
end

-- Smyčka pro automatický nákup
spawn(function()
    while task.wait(1) do
        for name, enabled in pairs(settings.Seeds) do
            if enabled then doPurchase(name) end
        end
        for name, enabled in pairs(settings.Gears) do
            if enabled then doPurchase(name) end
        end
    end
end)

-- GUI Taby
local Tab1 = Window:CreateTab("Seed Shop", 4483362458)
for name, _ in pairs(settings.Seeds) do
    Tab1:CreateToggle({
        Name = "Auto Buy " .. name,
        CurrentValue = false,
        Callback = function(v) settings.Seeds[name] = v end
    })
end

local Tab2 = Window:CreateTab("Gear Shop", 4483362458)
for name, _ in pairs(settings.Gears) do
    Tab2:CreateToggle({
        Name = "Auto Buy " .. name,
        CurrentValue = false,
        Callback = function(v) settings.Gears[name] = v end
    })
end

local InfoTab = Window:CreateTab("Status", 4483362458)
InfoTab:CreateLabel("Anti-AFK: AKTIVNÍ")
