-- Načtení Rayfield UI
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Garden Horizons | Full Auto Shop",
   LoadingTitle = "Načítám všechna semínka...",
   ConfigurationSaving = { Enabled = false }
})

-- ANTI-AFK (Zabrání kicku ze hry)
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

local settings = { Items = {} }

-- FUNKCE PRO TVŮJ GITHUB LOADSTRING
local function executeGithubScript(itemName)
    _G.TargetItem = itemName
    -- pcall zabrání zamrznutí GUI při chybě v načítání
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/deafyisgoingnow-spec/Auto-farm-donation-clicker/refs/heads/main/Garden%20horizons"))()
    end)
    if not success then warn("Chyba loadstringu: " .. err) end
end

-- Hlavní smyčka nákupu
spawn(function()
    while task.wait(0.7) do
        for name, enabled in pairs(settings.Items) do
            if enabled then executeGithubScript(name) end
        end
    end
end)

