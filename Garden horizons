local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Garden Horizons | Ultra Auto Buy",
   LoadingTitle = "Příprava na nákupy...",
   ConfigurationSaving = { Enabled = false }
})

local settings = {
    Seeds = {
        ["Mushroom Seed"] = false, ["Beetroot Seed"] = false, ["Tomato Seed"] = false,
        ["Apple Seed"] = false, ["Rose Seed"] = false, ["Wheat Seed"] = false,
        ["Banana Seed"] = false, ["Plum Seed"] = false, ["Potato Seed"] = false,
        ["Cabbage Seed"] = false, ["Cherry Seed"] = false
    },
    Gears = {
        ["Watering Can"] = false, ["Basic Sprinkler"] = false, ["Harvest Bell"] = false,
        ["Turbo Sprinkler"] = false, ["Favorite Tool"] = false, ["Super Sprinkler"] = false
    }
}

-- Tato funkce prohledá hru a zkusí najít nákupní příkaz
local function doPurchase(itemName)
    -- Hledáme v ReplicatedStorage eventy pro nákup
    local RS = game:GetService("ReplicatedStorage")
    local events = {"PurchaseItem", "BuyItem", "RequestPurchase", "ShopRemote"}
    
    for _, eventName in pairs(events) do
        local remote = RS:FindFirstChild(eventName, true)
        if remote and remote:IsA("RemoteEvent") then
            remote:FireServer(itemName)
        end
    end
end

-- Smyčka pro automatické klikání na pozadí
spawn(function()
    while task.wait(0.3) do
        for name, enabled in pairs(settings.Seeds) do
            if enabled then doPurchase(name) end
        end
        for name, enabled in pairs(settings.Gears) do
            if enabled then doPurchase(name) end
        end
    end
end)

