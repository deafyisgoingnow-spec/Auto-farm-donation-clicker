-- SEED SHOP (Všechny rostliny z tvých videí)
local SeedTab = Window:CreateTab("Seed Shop", 4483362458)
local allSeeds = {
    "Corn Seed", "Onion Seed", "Strawberry Seed", "Mushroom Seed", 
    "Beetroot Seed", "Tomato Seed", "Apple Seed", "Rose Seed", 
    "Wheat Seed", "Banana Seed", "Plum Seed", "Potato Seed", 
    "Cabbage Seed", "Cherry Seed", "Carrot Seed"
}

for _, name in pairs(allSeeds) do
    settings.Items[name] = false
    SeedTab:CreateToggle({
       Name = "Auto Buy " .. name,
       CurrentValue = false,
       Callback = function(v) settings.Items[name] = v end,
    })
end

