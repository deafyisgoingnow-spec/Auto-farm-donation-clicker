local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Grow a Garden 2 | Hackee Hub",
   LoadingTitle = "Načítání skriptu...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "GAG2_Hackee",
      FileName = "config"
   }
})

-- Proměnné pro nastavení (Toggles)
local AutoBuySeeds = false
local AutoBuyGear = false

-- Tabulka pro vybrané seedy
local SelectedSeeds = {
   ["Carrot"] = false,
   ["Bamboo"] = false,
   ["Mushroom"] = false,
   ["Venom spitter"] = false,
   ["Moon bloom"] = false,
   ["Dragon's breath"] = false,
   ["Hypno bloom"] = false
}

-- Tabulka pro vybraný gear
local SelectedGear = {
   ["Common watering can"] = false,
   ["Basic pot"] = false,
   ["Legendary sprinkler"] = false,
   ["Super sprinkler"] = false,
   ["Super watering can"] = false
}

-- REPLICATED STORAGE / REMOTES PATH (Cesty pro nákup v GAG2)
-- Poznámka: Pokud hra změní názvy Remotes, je potřeba upravit tyto cesty.
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local BuySeedRemote = ReplicatedStorage:FindFirstChild("BuySeed") or ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("BuySeed")
local BuyGearRemote = ReplicatedStorage:FindFirstChild("BuyGear") or ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("BuyGear")

-- ZÁLOŽKA: SEED SHOP
local SeedTab = Window:CreateTab("Seed Shop", 4483362458) -- Ikona listu

SeedTab:CreateToggle({
   Name = "💡 Zapnout/Vypnout nákup Seedů",
   CurrentValue = false,
   Flag = "ToggleSeeds",
   Callback = function(Value)
      AutoBuySeeds = Value
   end,
})

SeedTab:CreateSection("Které seedy kupovat:")

for seedName, _ in pairs(SelectedSeeds) do
   SeedTab:CreateToggle({
      Name = "Kupovat " .. seedName,
      CurrentValue = false,
      Callback = function(Value)
         SelectedSeeds[seedName] = Value
      end,
   })
end

-- ZÁLOŽKA: GEAR SHOP
local GearTab = Window:CreateTab("Gear Shop", 4483362601) -- Ikona nářadí

GearTab:CreateToggle({
   Name = "💡 Zapnout/Vypnout nákup Gearu",
   CurrentValue = false,
   Flag = "ToggleGear",
   Callback = function(Value)
      AutoBuyGear = Value
   end,
})

GearTab:CreateSection("Které vybavení kupovat:")

for gearName, _ in pairs(SelectedGear) do
   GearTab:CreateToggle({
      Name = "Kupovat " .. gearName,
      CurrentValue = false,
      Callback = function(Value)
         SelectedGear[gearName] = Value
      end,
   })
end

-- NEKONEČNÉ SMYČKY NA POZADÍ (AUTOMATICKÝ NÁKUP)

-- Smyčka pro Seedy
task.spawn(function()
   while task.wait(0.5) do -- Kontrola každou půl vteřinu (nezpůsobí lagy a koupí hned při restocku)
      if AutoBuySeeds then
         for seed, status in pairs(SelectedSeeds) do
            if status then
               -- Pokud máš zapnutý tento seed, pošle se příkaz hře ke koupi
               if BuySeedRemote then
                  BuySeedRemote:FireServer(seed)
               end
            end
         end
      end
   end
end)

-- Smyčka pro Gear (včetně tvého Legendary Sprinkleru)
task.spawn(function()
   while task.wait(0.5) do
      if AutoBuyGear then
         for gear, status in pairs(SelectedGear) do
            if status then
               -- Pokud máš zapnutý tento gear, pošle se příkaz hře ke koupi
               if BuyGearRemote then
                  BuyGearRemote:FireServer(gear)
               end
            end
         end
      end
   end
end)

Rayfield:Notify({
   Title = "Skript připraven!",
   Content = "Můžeš začít ovládat Seed a Gear shop.",
   Duration = 5,
   Image = 4483362458,
})
