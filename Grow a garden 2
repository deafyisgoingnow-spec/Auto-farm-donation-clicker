-- Logika farmení
local _G = _G or {}
_G.SeedFarmActive = false

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Funkce, která bezpečně sebere nalezený seed
local function collectSeed(seed)
    local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if rootPart and seed:IsA("BasePart") or seed:IsA("Model") then
        -- Teleportace mírně nad seed, aby postava nezapadla
        rootPart.CFrame = seed:GetPivot() * CFrame.new(0, 1.5, 0)
        task.wait(0.25) -- Čas pro hru, aby zaregistrovala, že tu stojíš
        
        -- Hledání ProximityPromptu (tlačítka pro sebrání)
        local prompt = seed:FindFirstChildOfClass("ProximityPrompt") or seed:FindFirstChildHierarchy("ProximityPrompt")
        if prompt then
            -- Podržení a zmáčknutí tlačítka přes executor
            fireproximityprompt(prompt, 1)
        end
        task.wait(0.35) -- Bezpečnostní pauza před dalším teleportem proti kicku
    end
end

-- Nekonečná smyčka běžící na pozadí
task.spawn(function()
    while true do
        if _G.SeedFarmActive then
            local foundSeed = false
            
            -- Prohledá celou mapu (workspace)
            for _, item in pairs(workspace:GetDescendants()) do
                if _G.SeedFarmActive == false then break end
                
                -- Kontrola správných názvů seedů
                if item.Name == "Gold Seed" or item.Name == "Rainbow Seed" or item.Name == "Mega Seed" then
                    foundSeed = true
                    collectSeed(item)
                end
            end
            
            -- Pokud na mapě zrovna žádný vzácný seed není, chvíli počká a zkusí to znova
            if not foundSeed then
                task.wait(1)
            end
        else
            task.wait(0.5) -- Pokud je farm vypnutá, skript odpočívá
        end
    end
end)

-- Funkce tlačítka pro zapnutí/vypnutí
ToggleButton.MouseButton1Click:Connect(function()
    _G.SeedFarmActive = not _G.SeedFarmActive
    if _G.SeedFarmActive then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Zelená
        ToggleButton.Text = "AUTOFARM: ZAPNUTO"
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Červená
        ToggleButton.Text = "AUTOFARM: VYPNUTO"
    end
end)
