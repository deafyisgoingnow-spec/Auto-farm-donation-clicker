local KavoUi = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = KavoUi.CreateLib("Grow a Garden 2 | Hackee Hub", "DarkTheme")

-- Hlavní vypínače
local AutoBuySeeds = false
local AutoBuyGear = false

-- Seznamy položek přesně podle tvého videa
local SeedOrder = {
   "Carrot", "Strawberry", "Blueberry", "Tulip", "Tomato", "Apple", "Bamboo",
   "Corn", "Cactus", "Pineapple", "Mushroom", "Green Bean", "Banana", "Grape",
   "Coconut", "Mango", "Dragon Fruit", "Acorn", "Cherry", "Sunflower",
   "Venus Fly Trap", "Pomegranate", "Poison Apple", "Venom Splitter",
   "Moon Bloom", "Hypno Bloom", "Dragon's Breath"
}

local GearOrder = {
   "Common Watering Can", "Common Sprinkler", "Sign", "Uncommon Sprinkler",
   "Trowel", "Rare Sprinkler", "Jump Mushroom", "Speed Mushroom", "Megaphone",
   "Shrink Mushroom", "Supersize Mushroom", "Gnome", "Flashbang", "Basic Pot",
   "Invisibility Mushroom", "Legendary Sprinkler", "Wheelbarrow", "Player Magnet",
   "Strawberry Sniper", "Super Watering Can", "Super Sprinkler"
}

-- Příprava tabulek pro uložení zapnutých položek
local SelectedSeeds = {}
for _, seed in ipairs(SeedOrder) do SelectedSeeds[seed] = false end

local SelectedGear = {}
for _, gear in ipairs(GearOrder) do SelectedGear[gear] = false end

-- Vyhledání síťových příkazů (Remotes) hry
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local BuySeedRemote = ReplicatedStorage:FindFirstChild("BuySeed", true) or ReplicatedStorage:FindFirstChild("Seed", true)
local BuyGearRemote = ReplicatedStorage:FindFirstChild("BuyGear", true) or ReplicatedStorage:FindFirstChild("Gear", true)

-- STRÁNKA: SEED SHOP
local SeedPage = Window:NewTab("Seed Shop")
local SeedSection = SeedPage:NewSection("Nákup Semínek")

SeedSection:NewToggle("💡 ZAPNOUT NÁKUP SEEDŮ", "Zapne/vypne automatické kupování vybraných seedů", function(state)
    AutoBuySeeds = state
end)

for _, seedName in ipairs(SeedOrder) do
    SeedSection:NewToggle("Kupovat " .. seedName, "Přidat do nákupního seznamu", function(state)
        SelectedSeeds[seedName] = state
    end)
end

-- STRÁNKA: GEAR SHOP
local GearPage = Window:NewTab("Gear Shop")
local GearSection = GearPage:NewSection("Nákup Vybavení")

GearSection:NewToggle("💡 ZAPNOUT NÁKUP GEARU", "Zapne/vypne automatické kupování vybraného gearu", function(state)
    AutoBuyGear = state
end)

for _, gearName in ipairs(GearOrder) do
    GearSection:NewToggle("Kupovat " .. gearName, "Přidat do nákupního seznamu", function(state)
        SelectedGear[gearName] = state
    end)
end

-- SMYČKY PRO NÁKUP NA POZADÍ
task.spawn(function()
   while task.wait(0.3) do
      if AutoBuySeeds and BuySeedRemote then
         for seed, status in pairs(SelectedSeeds) do
            if status then
               BuySeedRemote:FireServer(seed)
            end
         end
      end
   end
end)

task.spawn(function()
   while task.wait(0.3) do
      if AutoBuyGear and BuyGearRemote then
         for gear, status in pairs(SelectedGear) do
            if status then
               BuyGearRemote:FireServer(gear)
            end
         end
      end
   end
end)
