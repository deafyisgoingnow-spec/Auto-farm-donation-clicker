-- Čekání na načtení hry
if not game:IsLoaded() then game.Loaded:Wait() end

local lp = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = ReplicatedStorage:WaitForChild("Network")
local VU = game:GetService("VirtualUser")

-- ANTI-AFK (Běží neviditelně na pozadí)
lp.Idled:Connect(function()
    VU:CaptureController()
    VU:ClickButton2(Vector2.new())
end)

-- HLAVNÍ FUNKCE PRO ÚTOK NA BREAKABLES
local function startBreakableFarm()
    while true do
        pcall(function()
            local char = lp.Character or lp.CharacterAdded:Wait()
            local root = char:WaitForChild("HumanoidRootPart")
            
            -- Hledání nejbližšího breakable objektu
            local closest = nil
            local dist = math.huge
            local breakablesFolder = game.Workspace:WaitForChild("__THINGS"):WaitForChild("Breakables")
            
            for _, v in pairs(breakablesFolder:GetChildren()) do
                if v:IsA("Model") and v.PrimaryPart then
                    local d = (root.Position - v.PrimaryPart.Position).magnitude
                    if d < dist then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest then
                -- 1. TELEPORT: Přesun přímo k breakable
                root.CFrame = closest:GetModelCFrame()
                
                local targetId = closest.Name
                local startTime = tick()
                
                -- 2. SMYČKA ÚTOKU: Kliká a útočí, dokud breakable existuje
                -- (S pojistkou 5 vteřin pro případ zaseknutí v raidu)
                while closest and closest.Parent == breakablesFolder and (tick() - startTime < 5) do
                    
                    -- KLIKÁNÍ NA BREAKABLE (Network Call)
                    Network.Breakables_PlayerClick:FireServer(targetId)
                    
                    -- ÚTOK PETŮ (Network Call)
                    Network.Breakables_PlayerAttack:FireServer(targetId)
                    
                    -- SBĚR VŠEHO (Gemy, Orby, Drops)
                    Network.Orb_Collect:FireServer()
                    
                    task.wait(0.01) -- Maximální rychlost klikání
                end
            end
        end)
        task.wait(0.05) -- Krátká pauza na refresh cílů
    end
end

-- AUTOMATICKÉ SPUŠTĚNÍ PO NAČTENÍ
task.spawn(startBreakableFarm)

-- AUTO-REJOIN (Při odpojení tě hodí zpět)
game:GetService("CoreGui").RobloxPromptGui.promptOverlay.ChildAdded:Connect(function(child)
    if child.Name == "ErrorPrompt" then
        task.wait(2)
        game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
    end
end)
