    game.Loaded:Wait()
end

local lp = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

-- ANTI-AFK (Běží neviditelně na pozadí)
lp.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- HLAVNÍ FUNKCE: AGRESIVNÍ KLIKÁNÍ + TELEPORT
local function runUltimateFarm()
    while true do
        pcall(function()
            local char = lp.Character or lp.CharacterAdded:Wait()
            local root = char:WaitForChild("HumanoidRootPart")
            
            -- Najde nejbližší objekt (Breakable)
            local closest = nil
            local dist = math.huge
            local breakables = game.Workspace:WaitForChild("__THINGS"):WaitForChild("Breakables"):GetChildren()
            
            for _, v in pairs(breakables) do
                if v:IsA("Model") and v.PrimaryPart then
                    local d = (root.Position - v.PrimaryPart.Position).magnitude
                    if d < dist then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest then
                -- 1. TELEPORT: Okamžitý skok k cíli
                root.CFrame = closest:GetModelCFrame()
                
                -- 2. KLIKACÍ SMYČKA: Tady to buší do truhly
                local targetId = closest.Name
                -- Smyčka běží, dokud truhla existuje (nebo max 4 vteřiny pro raid bezpečí)
                local start = tick()
                while closest and closest.Parent and (tick() - start < 4) do
                    -- ÚTOK PETŮ
                    ReplicatedStorage.Network.Breakables_PlayerAttack:FireServer(targetId)
                    
                    -- EXTRÉMNÍ KLIKÁNÍ (To, co ti minule chybělo)
                    -- Posílá 2 kliky v jednom cyklu pro maximální rychlost
                    ReplicatedStorage.Network.Breakables_PlayerClick:FireServer(targetId)
                    ReplicatedStorage.Network.Breakables_PlayerClick:FireServer(targetId)
                    
                    -- SBĚR GEMŮ
                    ReplicatedStorage.Network.Orb_Collect:FireServer()
                    
                    task.wait(0.01) -- Maximální rychlost, kterou Roblox server pobere
                end
            end
        end)
        task.wait(0.05) -- Krátká pauza na refresh, pokud nic není v dosahu
    end
end

-- SPUŠTĚNÍ
task.spawn(runUltimateFarm)

-- AUTO-REJOIN (Návrat do hry při odpojení)
