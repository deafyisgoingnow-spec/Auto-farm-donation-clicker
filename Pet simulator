local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Pet Simulator 99: Event Hub",
   LoadingTitle = "Načítání pro Lukáše...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = { Enabled = true, Folder = "PetSimLukash" }
})

-- PROMĚNNÉ (Vypínače)
local _G = {
    AutoFarm = false,
    AutoCollect = false,
    AntiAfk = false,
    EditModeLoop = false
}

-- [TAB: HLAVNÍ FARMA]
local MainTab = Window:CreateTab("Farma", 4483362458)

MainTab:CreateToggle({
   Name = "Auto-Farm (Chests/Pots/Coins)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  pcall(function()
                      local things = workspace.__THINGS.Breakables:GetChildren()
                      local lp = game.Players.LocalPlayer
                      local root = lp.Character.HumanoidRootPart
                      local closest = nil
                      local dist = math.huge

                      for _, v in pairs(things) do
                          if v:IsA("Model") and v.PrimaryPart then
                              local d = (root.Position - v.PrimaryPart.Position).magnitude
                              if d < dist then
                                  dist = d
                                  closest = v
                              end
                          end
                      end

                      if closest then
                          root.CFrame = closest:GetModelCFrame()
                          game:GetService("ReplicatedStorage").Network.Breakables_PlayerClick:FireServer(closest.Name)
                          game:GetService("ReplicatedStorage").Network.Breakables_PlayerAttack:FireServer(closest.Name)
                      end
                  end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto-Collect (Teleport k Orbům/Drops)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  pcall(function()
                      local orbs = workspace.__THINGS.Orbs:GetChildren()
                      local root = game.Players.LocalPlayer.Character.HumanoidRootPart
                      for _, v in pairs(orbs) do
                          if v:IsA("Part") or v:IsA("MeshPart") then
                              root.CFrame = v.CFrame -- Teleport k orbu
                              game:GetService("ReplicatedStorage").Network.Orb_Collect:FireServer()
                              task.wait(0.05)
                          end
                      end
                  end)
                  task.wait(0.5)
              end
          end)
      end
   end,
})

-- [TAB: AUTOMATIZACE]
local UtilsTab = Window:CreateTab("Utility", 4483345906)

UtilsTab:CreateToggle({
   Name = "Anti-AFK (Jump & Move)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AntiAfk = Value
      if Value then
          task.spawn(function()
              while _G.AntiAfk do
                  local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                  if hum then
                      hum.Jump = true -- Výskok
                  end
                  task.wait(math.random(60, 110)) -- Každých cca 1.5 - 2 minuty
              end
          end)
      end
   end,
})

UtilsTab:CreateToggle({
   Name = "Auto-Edit Pet Mode (2 min Loop)",
   CurrentValue = false,
   Callback = function(Value)
      _G.EditModeLoop = Value
      if Value then
          task.spawn(function()
              while _G.EditModeLoop do
                  -- Zapnout Edit Mode
                  game:GetService("ReplicatedStorage").Network.Pet_EditMode_Enable:FireServer()
                  task.wait(2) -- Krátká pauza
                  -- Vypnout Edit Mode
                  game:GetService("ReplicatedStorage").Network.Pet_EditMode_Disable:FireServer()
                  task.wait(120) -- Počkej 2 minuty
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Skript spuštěn!",
   Content = "Vítej Lukáši, tvoje menu je připraveno.",
   Duration = 5,
   Image = 4483345906,
})
