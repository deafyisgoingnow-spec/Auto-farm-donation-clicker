-- Čekání na načtení hry pro tvé Redmi 13C
if not game:IsLoaded() then game.Loaded:Wait() end

local lp = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local Net = RS:WaitForChild("Network")
local VU = game:GetService("VirtualUser")

-- ANTI-AFK (Běží neviditelně)
lp.Idled:Connect(function()
    VU:CaptureController()
    VU:ClickButton2(Vector2.new())
end)

-- FUNKCE PRO SBĚR VŠEHO (Magnet)
local function collectDrops()
    pcall(function()
        Net.Orb_Collect:FireServer()
        Net.Lootbag_Collect_All:FireServer()
    end)
end

-- INTELIGENTNÍ HLEDÁNÍ CÍLE (Priorita: Pot of Gold > Chests > Breakables)
local function getBestTarget()
    pcall(function()
        local things = workspace:WaitForChild("__THINGS"):WaitForChild("Breakables")
        local children = things:GetChildren()
        local closest = nil
        local dist = math.huge
        local charPos = lp.Character.HumanoidRootPart.Position

        -- 1. PRIORITA: Pot of Gold (Nejdůležitější v eventu)
        for _, v in pairs(children) do
            if v:IsA("Model") and v.PrimaryPart then
                local name = v.Name:lower()
                if name:find("pot of gold") or name:find("potofgold") then
                    return v 
                end
            end
        end

        -- 2. PRIORITA: Jakákoliv Chest
        for _, v in pairs(children) do
            if v:IsA("Model") and v.PrimaryPart then
                if v.Name:lower():find("chest") then
                    return v
                end
            end
        end

        -- 3. PRIORITA: Nejbližší Breakable
        for _, v in pairs(children) do
            if v:IsA("Model") and v.PrimaryPart then
                local d = (charPos - v.PrimaryPart.Position).magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
        return closest
    end)
end

-- HLAVNÍ SMYČKA FARMY
local function startUltimateFarm()
    while true do
        pcall(function()
            local target = getBestTarget()
            
            if target then
                local targetId = target.Name
                local root = lp.Character.HumanoidRootPart
                
                -- TELEPORT: Přímo k objektu
                root.CFrame = target:GetModelCFrame()
                
                -- EXTRÉMNÍ ÚTOK (Klikání a Pety)
                local startTick = tick()
                -- U Pot of Gold/Chest zůstane déle (8s), u malých věcí kratší dobu
                local maxTime = target.Name:lower():find("pot") and 8 or 5
                
                while target and target.Parent and (tick() - startTick < maxTime) do
                    -- Útok petů
                    Net.Breakables_PlayerAttack:FireServer(targetId)
                    
                    -- MEGA AUTO-CLICK (Dvojitý signál pro rychlost)
                    Net.Breakables_PlayerClick:FireServer(targetId)
                    Net.Breakables_PlayerClick:FireServer(targetId)
                    
                    -- Průběžný sběr všeho kolem
                    collectDrops()
                    
                    task.wait(0.01) -- Max rychlost pro Redmi 13C
                end
            end
        end)
        task.wait(0.05) -- Rychlý refresh pro další cíl
    end
end

-- SPUŠTĚNÍ
task.spawn(startUltimateFarm)

