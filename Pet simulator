-- Čekání na hru
if not game:IsLoaded() then game.Loaded:Wait() end

local lp = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local Net = RS:WaitForChild("Network")

-- ANTI-AFK (Neviditelný, aby tě server neodpojil)
local VU = game:GetService("VirtualUser")
lp.Idled:Connect(function()
    VU:CaptureController()
    VU:ClickButton2(Vector2.new())
end)

-- FUNKCE PRO SBĚR VŠEHO, CO PADÁ (Gemy, Itemy, Orby)
local function collectEverything()
    pcall(function()
        -- Vyvolá hromadný sběr všech orbů v okolí
        Net:WaitForChild("Orb_Collect"):FireServer()
        -- Alternativní metoda pro novější verze raidu
        for _, v in pairs(game.Workspace.__THINGS.Orbs:GetChildren()) do
            if v:IsA("Part") or v:IsA("MeshPart") then
                Net:WaitForChild("Orb_Pickup"):FireServer(v.Name)
            end
        end
    end)
end

-- HLAVNÍ FUNKCE: TELEPORT + AGRESIVNÍ KLIKÁNÍ
local function startUltimateFarm()
    while true do
        pcall(function()
            local char = lp.Character or lp.CharacterAdded:Wait()
            local root = char:WaitForChild("HumanoidRootPart")
            
            -- Najde nejbližší cíl
            local closest = nil
            local dist = math.huge
            local breakables = game.Workspace:WaitForChild("__THINGS"):WaitForChild("Breakables"):GetChildren()
            
            for _, v in pairs(breakables) do
                if v:IsA("Model") and v.PrimaryPart then
                    local d = (root.Position - v.PrimaryPart.Position).magnitude
                    if d < dist then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest then
                -- 1. TELEPORT: Hodí tě přímo na truhlu
                root.CFrame = closest:GetModelCFrame()
                
                local targetId = closest.Name
                local startTick = tick()
                
                -- 2. SMYČKA PRO KLIKÁNÍ A ÚTOK (Dokud truhla žije)
                while closest and closest.Parent and (tick() - startTick < 3) do
                    -- ÚTOK PETŮ
                    Net:WaitForChild("Breakables_PlayerAttack"):FireServer(targetId)
                    
                    -- RYCHLÝ AUTO-CLICK (2x pro jistotu)
                    Net:WaitForChild("Breakables_PlayerClick"):FireServer(targetId)
                    Net:WaitForChild("Breakables_PlayerClick"):FireServer(targetId)
                    
                    -- PRŮBĚŽNÝ SBĚR PADÁVAJÍCÍCH VĚCÍ
                    collectEverything()
                    
                    task.wait(0.01) -- Maximální povolená rychlost
                end
            end
        end)
        -- Malá pauza, aby se mobil nepřehřál a stihl načíst další truhly v raidu
        task.wait(0.05)
    end
end

-- SPUŠTĚNÍ AUTOMATICKY PO NAČTENÍ
task.spawn(startUltimateFarm)

-- AUTO-REJOIN (Při pádu tě vrátí zpět)
game:GetService("CoreGui").RobloxPromptGui.promptOverlay.ChildAdded:Connect(function(child)
    if child.Name == "ErrorPrompt" then
        task.wait(3)
        game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
    end
end)
