local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "DARK BYTE",
   LoadingTitle = "Full Auto Raid Mode...",
   LoadingSubtitle = "Optimalizováno pro 300M Goal",
   ConfigurationSaving = { Enabled = false }
})

-- PROMĚNNÉ
local lp = game.Players.LocalPlayer
local char = lp.Character or lp.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local autoRaid = false

-- FUNKCE: TELEPORT A ÚTOK
local function farmClosest()
    local closest = nil
    local dist = math.huge
    
    -- Hledání nejbližšího breakable v Raidu
    pcall(function()
        for _, v in pairs(game.Workspace.__THINGS.Breakables:GetChildren()) do
            if v:IsA("Model") and not v.Name:lower():find("boss") then
                local d = (root.Position - v:GetModelCFrame().p).magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
        
        if closest then
            -- Teleport k věci
            root.CFrame = closest:GetModelCFrame()
            -- Útok petů
            game:GetService("ReplicatedStorage").Network.Breakables_PlayerAttack:FireServer(closest.Name)
            -- Sběr orbů
            game:GetService("ReplicatedStorage").Network.Orb_Collect:FireServer()
        end
    end)
end

-- KATEGORIE: EVENT
local EventTab = Window:CreateTab("Auto Raid", 4483362458)

EventTab:CreateToggle({
   Name = "Full Auto: Start + Farm + Loot",
   CurrentValue = false,
   Callback = function(v)
      autoRaid = v
      task.spawn(function()
         while autoRaid do
            -- 1. Pokud nejsi v Raidu, zkus ho odstartovat (Level 4500)
            if not game.Workspace.__THINGS.Breakables:FindFirstChildWhichIsA("Model") then
                game:GetService("ReplicatedStorage").Network:FindFirstChild("Raid_Start"):InvokeServer("StPatrick", 4500)
                task.wait(2)
            end
            
            -- 2. Farmení a teleportace
            farmClosest()
            
            -- 3. Kontrola lootu na konci (Teleport k chestkám)
            pcall(function()
                for _, chest in pairs(game.Workspace.__THINGS.LootChest:GetChildren()) do
                    if not chest:FindFirstChild("Locked") then
                        root.CFrame = chest:GetModelCFrame()
                        game:GetService("ReplicatedStorage").Network.LootChest_Collect:FireServer(chest.Name)
                        task.wait(0.5)
                    end
                end
            end)
            
            task.wait(0.1)
         end
      end)
   end,
})

