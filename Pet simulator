local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "DARK BYTE",
   LoadingTitle = "Smart Teleport System",
   LoadingSubtitle = "Redmi 13C 5G Optimized",
   ConfigurationSaving = { Enabled = false }
})

-- PROMĚNNÉ
local lp = game.Players.LocalPlayer
local vu = game:GetService("VirtualUser")
local autoRaid = false

-- FUNKCE: KONTROLA, ZDA JSEM V RAIDU (Podle tvého videa)
local function isInRaid()
    -- V raidu se vždy objeví specifické věci v Workspace.__THINGS.Breakables
    local breakables = game.Workspace.__THINGS.Breakables:GetChildren()
    return #breakables > 0
end

-- KATEGORIE: EVENT
local EventTab = Window:CreateTab("Auto Raid", 4483362458)

EventTab:CreateToggle({
   Name = "FULL AUTO (Safe Teleport)",
   CurrentValue = false,
   Callback = function(v)
      autoRaid = v
      task.spawn(function()
         while autoRaid do
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) continue end

            -- 1. POKUD JSEM VENKU (Raid neběží): Jen klikej na Start a neportuj se!
            if not isInRaid() then
                pcall(function()
                    -- Klikání na "Create" a "Start" v UI menu z tvého videa
                    game:GetService("ReplicatedStorage").Network.Raid_Create:InvokeServer("StPatrick", 4500)
                    task.wait(0.5)
                    game:GetService("ReplicatedStorage").Network.Raid_Start:InvokeServer()
                    
                    -- Kontrola truhel na konci (Lootování se zapne jen když vidí chestku)
                    for _, chest in pairs(game.Workspace.__THINGS:GetChildren()) do
                        if chest.Name:find("Chest") or chest.Name:find("Loot") then
                            root.CFrame = chest:GetModelCFrame()
                            game:GetService("ReplicatedStorage").Network.LootChest_Collect:FireServer(chest.Name)
                            task.wait(0.5)
                        end
                    end
                end)
            end

            -- 2. POKUD JSEM V RAIDU: Zapni teleportaci k truhlám
            if isInRaid() then
                pcall(function()
                    local closest = nil
                    local dist = math.huge
                    for _, b in pairs(game.Workspace.__THINGS.Breakables:GetChildren()) do
                        if not b.Name:lower():find("boss") then
                            local d = (root.Position - b:GetModelCFrame().p).magnitude
                            if d < dist then dist = d; closest = b end
                        end
                    end
                    if closest then
                        -- TELEPORT AKTIVNÍ POUZE ZDE
                        root.CFrame = closest:GetModelCFrame()
                        game:GetService("ReplicatedStorage").Network.Breakables_PlayerAttack:FireServer(closest.Name)
                    end
                end)
            end
            
            task.wait(0.1)
         end
      end)
   end,
})

