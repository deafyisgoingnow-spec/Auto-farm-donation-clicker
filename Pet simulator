local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "DARK BYTE",
   LoadingTitle = "Full Automation System",
   LoadingSubtitle = "Redmi 13C 5G Optimized",
   ConfigurationSaving = { Enabled = false }
})

-- PROMĚNNÉ
local lp = game.Players.LocalPlayer
local root = lp.Character:WaitForChild("HumanoidRootPart")
local autoRaid = false
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- 1. FUNKCE: AUTO-START RAID (Klikání na UI)
local function handleRaidStart()
    pcall(function()
        -- Simulace příkazů pro spuštění raidu 4500
        ReplicatedStorage.Network.Raid_Create:InvokeServer("StPatrick", 4500)
        task.wait(0.5)
        ReplicatedStorage.Network.Raid_Start:InvokeServer()
    end)
end

-- 2. FUNKCE: TELEPORT & ÚTOK (Na nejbližší věc)
local function farmStep()
    pcall(function()
        local closest = nil
        local dist = math.huge
        local breakables = game.Workspace.__THINGS.Breakables:GetChildren()
        
        for _, b in pairs(breakables) do
            if b:IsA("Model") and not b.Name:lower():find("boss") then
                local pos = b:GetModelCFrame().p
                local d = (root.Position - pos).magnitude
                if d < dist then
                    dist = d
                    closest = b
                end
            end
        end
        
        if closest then
            root.CFrame = closest:GetModelCFrame()
            ReplicatedStorage.Network.Breakables_PlayerAttack:FireServer(closest.Name)
            ReplicatedStorage.Network.Orb_Collect:FireServer()
        end
    end)
end

-- 3. FUNKCE: AUTO-LOOT (Truhly na konci)
local function collectLoot()
    pcall(function()
        for _, chest in pairs(game.Workspace.__THINGS:GetChildren()) do
            if (chest.Name:find("Chest") or chest.Name:find("Loot")) and not chest:FindFirstChild("Locked") then
                root.CFrame = chest:GetModelCFrame() * CFrame.new(0, 2, 0)
                ReplicatedStorage.Network.LootChest_Collect:FireServer(chest.Name)
                task.wait(0.3)
            end
        end
    end)
end

-- KATEGORIE: MAIN AUTOMATION
local EventTab = Window:CreateTab("Auto Raid", 4483362458)

EventTab:CreateToggle({
   Name = "FULL AUTO (Start + Farm + Loot)",
   CurrentValue = false,
   Callback = function(v)
      autoRaid = v
      task.spawn(function()
         while autoRaid do
            -- Krok 1: Zkus odstartovat, pokud jsi venku
            handleRaidStart()
            
            -- Krok 2: Farmení (Teleportace)
            farmStep()
            
            -- Krok 3: Kontrola a sebrání lootu
            collectLoot()
            
            task.wait(0.1)
         end
      end)
   end,
})

