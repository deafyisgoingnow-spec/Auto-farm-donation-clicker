local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Pet Simulator 99: Pro Hub",
   LoadingTitle = "Načítání pro Lukáše...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = { Enabled = true, Folder = "PetSimLukash" }
})

local _G = {
    AutoFarm = false,
    AutoCollect = false,
    AntiAfk = false,
    PetResetLoop = false
}

-- [TAB: HLAVNÍ FARMA]
local MainTab = Window:CreateTab("Farma", 4483362458)

MainTab:CreateToggle({
   Name = "Auto-Farm (Clicker + TP)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  pcall(function()
                      local things = workspace.__THINGS.Breakables:GetChildren()
                      local lp = game.Players.LocalPlayer
                      local root = lp.Character.HumanoidRootPart
                      local closest = nil
                      local dist = math.huge

                      for _, v in pairs(things) do
                          if v:IsA("Model") and v.PrimaryPart then
                              local d = (root.Position - v.PrimaryPart.Position).magnitude
                              if d < dist then
                                  dist = d
                                  closest = v
                              end
                          end
                      end

                      if closest then
                          root.CFrame = closest:GetModelCFrame()
                          local net = game:GetService("ReplicatedStorage").Network
                          -- Klikání, které neovlivňuje tvou hru
                          net.Breakables_PlayerClick:FireServer(closest.Name)
                          net.Breakables_PlayerAttack:FireServer(closest.Name)
                      end
                  end)
                  task.wait(0.05)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto-Collect (TP k Dropům)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  pcall(function()
                      local orbs = workspace.__THINGS.Orbs:GetChildren()
                      local root = game.Players.LocalPlayer.Character.HumanoidRootPart
                      for _, v in pairs(orbs) do
                          if v:IsA("Part") or v:IsA("MeshPart") then
                              root.CFrame = v.CFrame
                              game:GetService("ReplicatedStorage").Network.Orb_Collect:FireServer()
                              task.wait(0.02)
                          end
                      end
                  end)
                  task.wait(0.3)
              end
          end)
      end
   end,
})

-- [TAB: AUTOMATIZACE]
local UtilsTab = Window:CreateTab("Utility", 4483345906)

UtilsTab:CreateToggle({
   Name = "Pet Team Reset (Video Method)",
   CurrentValue = false,
   Callback = function(Value)
      _G.PetResetLoop = Value
      if Value then
          task.spawn(function()
              while _G.PetResetLoop do
                  pcall(function()
                      local net = game:GetService("ReplicatedStorage").Network
                      -- 1. Přepne na Team 2 (vyvolá reset)
                      net.Teams_Select:FireServer(2)
                      task.wait(0.5)
                      -- 2. Přepne zpět na Team 1 (přesně podle videa)
                      net.Teams_Select:FireServer(1)
                  end)
                  task.wait(120) -- Opakuje každé 2 minuty
              end
          end)
      end
   end,
})

UtilsTab:CreateToggle({
   Name = "Anti-AFK (Jump)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AntiAfk = Value
      if Value then
          task.spawn(function()
              while _G.AntiAfk do
                  local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                  if hum then hum.Jump = true end
                  task.wait(math.random(60, 110))
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Menu Načteno!",
   Content = "Farma připravena, Lukáši.",
   Duration = 5,
   Image = 4483345906,
})

