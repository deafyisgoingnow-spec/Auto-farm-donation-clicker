local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Pet Simulator 99: Hard Reset",
   LoadingTitle = "Simulace klikání...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = { Enabled = true, Folder = "PetSimLukash" }
})

local _G = {
    AutoFarm = false,
    AutoCollect = false,
    AntiAfk = false,
    PetResetLoop = false
}

local VU = game:GetService("VirtualUser")
local lp = game.Players.LocalPlayer

-- FUNKCE PRO KLIKÁNÍ NA OBRAZOVKU (Simulace prstu)
local function clickAt(x, y)
    VU:Button1Down(Vector2.new(x, y))
    task.wait(0.1)
    VU:Button1Up(Vector2.new(x, y))
end

-- [TAB: HLAVNÍ FARMA]
local MainTab = Window:CreateTab("Farma", 4483362458)

MainTab:CreateToggle({
   Name = "Auto-Farm (Simulated Clicks)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  pcall(function()
                      local things = workspace.__THINGS.Breakables:GetChildren()
                      local root = lp.Character.HumanoidRootPart
                      local closest = nil
                      local dist = math.huge

                      for _, v in pairs(things) do
                          if v:IsA("Model") and v.PrimaryPart then
                              local d = (root.Position - v.PrimaryPart.Position).magnitude
                              if d < dist then
                                  dist = d
                                  closest = v
                              end
                          end
                      end

                      if closest then
                          root.CFrame = closest:GetModelCFrame()
                          -- Klikne doprostřed obrazovky (na truhlu)
                          VU:Button1Down(Vector2.new(500, 500))
                          task.wait(0.05)
                          VU:Button1Up(Vector2.new(500, 500))
                      end
                  end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

-- [TAB: UTILITY]
local UtilsTab = Window:CreateTab("Utility", 4483345906)

UtilsTab:CreateToggle({
   Name = "Pet Team Reset (Manual UI - 1 min)",
   CurrentValue = false,
   Callback = function(Value)
      _G.PetResetLoop = Value
      if Value then
          task.spawn(function()
              while _G.PetResetLoop do
                  pcall(function()
                      -- 1. KLIK NA INVENTÁŘ (Tlačítko s pety dole)
                      clickAt(500, 900) 
                      task.wait(1)
                      
                      -- 2. KLIK NA TÝM #2 (Pozice tlačítka 2 v menu)
                      clickAt(450, 400) 
                      task.wait(0.5)
                      
                      -- 3. KLIK NA TÝM #1 (Pozice tlačítka 1 v menu)
                      clickAt(350, 400) 
                      task.wait(0.5)
                      
                      -- 4. ZAVŘÍT INVENTÁŘ (Křížek nahoře)
                      clickAt(900, 100) 
                  end)
                  task.wait(60) -- Každou minutu
              end
          end)
      end
   end,
})

UtilsTab:CreateToggle({
   Name = "Anti-AFK (Jump)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AntiAfk = Value
      if Value then
          task.spawn(function()
              while _G.AntiAfk do
                  local hum = lp.Character:FindFirstChildOfClass("Humanoid")
                  if hum then hum.Jump = true end
                  task.wait(45)
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Menu Načteno!",
   Content = "Simulované klikání aktivní (1 min reset).",
   Duration = 5
})
