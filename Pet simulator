-- Čeká na načtení hry
if not game:IsLoaded() then
    game.Loaded:Wait()
end

local lp = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

-- ANTI-AFK (Běží neviditelně)
lp.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- HLAVNÍ FUNKCE: AGRESIVNÍ TELEPORT & CLICK
local function runRaidFarm()
    while true do
        pcall(function()
            local char = lp.Character or lp.CharacterAdded:Wait()
            local root = char:WaitForChild("HumanoidRootPart")
            
            -- Hledání nejbližšího objektu (Breakable)
            local closest = nil
            local dist = math.huge
            local things = game.Workspace.__THINGS.Breakables:GetChildren()
            
            for _, v in pairs(things) do
                if v:IsA("Model") and v.PrimaryPart then
                    local d = (root.Position - v.PrimaryPart.Position).magnitude
                    if d < dist then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest then
                -- 1. TELEPORT: Hodí tě k objektu
                root.CFrame = closest:GetModelCFrame()
                
                -- 2. SMYČKA: Útoč na tuhle věc, dokud existuje
                -- Přidána kontrola, aby skript neusnul, když se v raidu změní vlna
                while closest and closest.Parent == game.Workspace.__THINGS.Breakables do
                    local targetId = closest.Name
                    
                    -- Útok petů a rychlé klikání přes server (neovlivňuje kameru)
                    ReplicatedStorage.Network.Breakables_PlayerAttack:FireServer(targetId)
                    ReplicatedStorage.Network.Breakables_PlayerClick:FireServer(targetId)
                    
                    -- Sběr gemů/orbů
                    ReplicatedStorage.Network.Orb_Collect:FireServer()
                    
                    task.wait(0.01) -- Max rychlost útoku
                    
                    -- Kontrola, jestli se mezitím neobjevilo něco blíž (důležité pro Raidy)
                    if math.random(1, 20) == 1 then break end 
                end
            end
        end)
        task.wait(0.05) -- Rychlý restart hledání, pokud nic není v dosahu
    end
end

-- SPUŠTĚNÍ
task.spawn(runRaidFarm)

-- AUTO-REJOIN
game:GetService("CoreGui").RobloxPromptGui.promptOverlay.ChildAdded:Connect(function(child)
    if child.Name == "ErrorPrompt" then
        task.wait(2)
        game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
    end
end)
