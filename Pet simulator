local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Pet Simulator 99: Pro Hub",
   LoadingTitle = "Oprava pro Lukáše...",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = { Enabled = true, Folder = "PetSimLukash" }
})

local _G = {
    AutoFarm = false,
    AutoCollect = false,
    AntiAfk = false,
    PetResetLoop = false
}

local Net = game:GetService("ReplicatedStorage"):WaitForChild("Network")

-- [TAB: HLAVNÍ FARMA]
local MainTab = Window:CreateTab("Farma", 4483362458)

MainTab:CreateToggle({
   Name = "Auto-Farm (Clicker + TP)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoFarm = Value
      if Value then
          task.spawn(function()
              while _G.AutoFarm do
                  pcall(function()
                      local things = workspace.__THINGS.Breakables:GetChildren()
                      local lp = game.Players.LocalPlayer
                      local root = lp.Character.HumanoidRootPart
                      local closest = nil
                      local dist = math.huge

                      for _, v in pairs(things) do
                          if v:IsA("Model") and v.PrimaryPart then
                              local d = (root.Position - v.PrimaryPart.Position).magnitude
                              if d < dist then
                                  dist = d
                                  closest = v
                              end
                          end
                      end

                      if closest then
                          root.CFrame = closest:GetModelCFrame()
                          -- Zkoušíme dvě různé cesty klikání pro jistotu
                          Net.Breakables_PlayerClick:FireServer(closest.Name)
                          Net.Clicking_PlayerClick:FireServer(closest.Name)
                      end
                  end)
                  task.wait(0.1)
              end
          end)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto-Collect (Drops)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoCollect = Value
      if Value then
          task.spawn(function()
              while _G.AutoCollect do
                  pcall(function()
                      Net.Orb_Collect:FireServer()
                      local orbs = workspace.__THINGS.Orbs:GetChildren()
                      for _, v in pairs(orbs) do
                          if v:IsA("Part") then
                              v.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
                          end
                      end
                  end)
                  task.wait(0.5)
              end
          end)
      end
   end,
})

-- [TAB: UTILITY]
local UtilsTab = Window:CreateTab("Utility", 4483345906)

UtilsTab:CreateToggle({
   Name = "Pet Team Reset (1 minuta)",
   CurrentValue = false,
   Callback = function(Value)
      _G.PetResetLoop = Value
      if Value then
          task.spawn(function()
              while _G.PetResetLoop do
                  pcall(function()
                      -- Použití InvokeServer (přesně to, co dělá hra v inventáři)
                      Net.Teams_Select:InvokeServer(2)
                      task.wait(1)
                      Net.Teams_Select:InvokeServer(1)
                  end)
                  task.wait(60) -- Reset každou 1 minutu
              end
          end)
      end
   end,
})

UtilsTab:CreateToggle({
   Name = "Anti-AFK (Jump)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AntiAfk = Value
      if Value then
          task.spawn(function()
              local VU = game:GetService("VirtualUser")
              game.Players.LocalPlayer.Idled:Connect(function()
                  VU:CaptureController()
                  VU:ClickButton2(Vector2.new())
              end)
              while _G.AntiAfk do
                  local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                  if hum then hum.Jump = true end
                  task.wait(30)
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Menu Načteno!",
   Content = "Opravený Reset (1 min) a Clicker.",
   Duration = 5
})
